# Server environment (copy to .env in project root or export before starting the server)

# Required in production — use a long random string
JWT_SECRET=

# Server port (default: 3010)
PORT=3010

# SQLite database file path (default: server/data/wishesdream.db)
DATABASE_PATH=

# Optional — improve Amazon product import when direct fetch is blocked
SCRAPERAPI_KEY=
MICROLINK_API_KEY=

# Optional — override path to built frontend (default: web/dist from repo root)
# WEB_DIST_PATH=../web/dist

# Public site URL for SEO (sitemap, robots.txt, canonical links)
# Production example: https://wishesdream.up.railway.app
SITE_URL=

# Set at web build time (Vite) — should match SITE_URL in production
# VITE_SITE_URL=https://wishesdream.up.railway.app
